# ---- OS ----
.DS_Store

# ---- Python ----
**/__pycache__/
*.pyc
.venv/
webapp/backend/.venv/

# PyInstaller sidecar build outputs (regenerated by CI / build:backend)
webapp/backend/dist_backend/
webapp/backend/build_backend/

# ---- Node / Bun ----
node_modules/
webapp/frontend/dist/
webapp/frontend/.vite/

# ---- Desktop build outputs ----
webapp/desktop/release/
webapp/desktop-macos/release/

# ---- Runtime data (NOT source) ----
# Instructor-authored problem sets, baked bundles, class codes, attempt logs and
# local config are all created at runtime. This ships as an empty-set app: there
# are no built-in problems, so nothing here is committed.
webapp/data/sets/
webapp/data/bundles/
webapp/data/classes/
webapp/data/attempts/
webapp/data/config.json

# ---- Local env / secrets ----
.env
*.local
