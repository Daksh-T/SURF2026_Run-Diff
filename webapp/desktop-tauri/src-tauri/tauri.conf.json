{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RunDiff",
  "version": "0.1.0",
  "identifier": "edu.sewanee.surf.rundiff",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Run·Diff",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "backgroundColor": "#f4f0e6"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Education",
    "shortDescription": "Socratic SQL tutor",
    "longDescription": "Run·Diff — a Socratic SQL tutor that runs locally as a desktop app.",
    "resources": [
      "resources/rundiff-backend/**/*",
      "resources/frontend-dist/**/*"
    ]
  }
}
